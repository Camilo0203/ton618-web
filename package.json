    "@tanstack/react-virtual": "^3.13.23",
    "clsx": "^2.1.1",
    "framer-motion": "^12.36.0",
    "i18next": "^25.8.18",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.13.1",
    "serve": "^14.2.6",
    "vite": "^5.4.2",
    "tailwind-merge": "^3.5.0",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.6"
