# ============================================
# BILLING BACKEND - Environment Variables
# ============================================
# Payment provider: Whop (Stripe was deprecated)

# ============================================
# FRONTEND (.env in ton618-web root)
# ============================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Whop plan IDs (from Whop Dashboard → Products)
VITE_WHOP_PLAN_MONTHLY=plan_xxxxxxxxxxxx
VITE_WHOP_PLAN_YEARLY=plan_yyyyyyyyyyyy
VITE_WHOP_PLAN_LIFETIME=plan_zzzzzzzzzzzz

# ============================================
# SUPABASE EDGE FUNCTIONS
# Set in: Supabase Dashboard → Project Settings → Edge Functions
# ============================================

# Supabase (auto-configured)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# Discord OAuth2
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=https://your-project.supabase.co/auth/v1/callback

# Whop
WHOP_WEBHOOK_SECRET=whop_webhook_secret_from_dashboard

# Whop plan IDs (same as frontend, used by webhook mapper)
WHOP_PLAN_MONTHLY=plan_xxxxxxxxxxxx
WHOP_PLAN_YEARLY=plan_yyyyyyyyyyyy
WHOP_PLAN_LIFETIME=plan_zzzzzzzzzzzz

# Bot API Key (shared secret between Supabase and Bot)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Must be the same in bot .env
BOT_API_KEY=your_secure_random_key_min_32_chars

# ============================================
# BOT (.env in ton618-bot root)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
BOT_API_KEY=your_secure_random_key_min_32_chars
# ^ Must match the BOT_API_KEY in Supabase Edge Functions
