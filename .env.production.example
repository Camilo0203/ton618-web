# ==========================================
# Supabase Edge Function Secrets (billing)
# Set these in Supabase Dashboard → Project Settings → Edge Functions, NOT here.
# Listed for reference so operators know what must be configured.
# ==========================================

# --- Whop (current payment provider) ---
# WHOP_WEBHOOK_SECRET=<secret from Whop Dashboard → Webhooks>
# WHOP_PLAN_MONTHLY=plan_xxxxxxxxxxxx
# WHOP_PLAN_YEARLY=plan_yyyyyyyyyyyy
# WHOP_PLAN_LIFETIME=plan_zzzzzzzzzzzz

# --- Discord OAuth (used by billing-create-checkout and billing-get-guilds) ---
# DISCORD_CLIENT_ID=<same as VITE_DISCORD_CLIENT_ID>
# DISCORD_CLIENT_SECRET=<from Discord Developer Portal → OAuth2>
# DISCORD_REDIRECT_URI=https://ton618.app/auth/callback
# DISCORD_BOT_TOKEN=<bot token, same as bot DISCORD_TOKEN — needed for guild enrichment>

# --- Supabase (server-side) ---
# BOT_API_KEY=<32-byte hex, must match EXACTLY the bot .env BOT_API_KEY>
# SUPABASE_SERVICE_ROLE_KEY=<service role key — never expose client-side>
# SUPABASE_URL=https://your-production-project.supabase.co
# SUPABASE_ANON_KEY=<same as VITE_SUPABASE_ANON_KEY>

# --- CORS: allowed origin in edge functions ---
# SITE_URL=https://ton618.app
