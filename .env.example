# ==========================================
# Variables Core (Requeridas)
# ==========================================

# Discord OAuth (Obtener desde Discord Developer Portal)
VITE_DISCORD_CLIENT_ID=your_discord_client_id
VITE_DISCORD_PERMISSIONS=8

# Supabase (Obtener desde la configuracion del proyecto > API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# URL base del sitio (usada para auth callbacks y SEO)
# En desarrollo local: http://localhost:5173
VITE_SITE_URL=http://localhost:5173

# ==========================================
# Variables de Branding y Enlaces (Opcionales)
# ==========================================
VITE_BOT_NAME=TON618
VITE_SUPPORT_SERVER_URL=https://discord.gg/your-support-server
VITE_DOCS_URL=https://docs.example.com
VITE_STATUS_URL=https://status.example.com
VITE_GITHUB_URL=https://github.com/your-org/ton618-web
VITE_TWITTER_URL=https://x.com/your-handle
VITE_CONTACT_EMAIL=support@example.com

VITE_DONATION_URL=
VITE_WHOP_DONATION_2=plan_donation_2
VITE_WHOP_DONATION_5=plan_donation_5
VITE_WHOP_DONATION_10=plan_donation_10
VITE_WHOP_DONATION_25=plan_donation_25
VITE_WHOP_PLAN_MONTHLY=plan_monthly
VITE_WHOP_PLAN_YEARLY=plan_yearly
VITE_WHOP_PLAN_LIFETIME=plan_lifetime

# Dashboard publico:
# - true + vacio => usa /dashboard
# - true + /dashboard => usa ruta interna
# - true + URL externa => abre esa URL
VITE_DASHBOARD_URL=
VITE_ENABLE_DASHBOARD=true
VITE_BILLING_BETA_MODE=false

# Stripe public key (REQUIRED for billing/checkout to work)
# Get from https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ==========================================
# Observabilidad (Opcional)
# ==========================================

# Bot health endpoint for public status page
VITE_BOT_HEALTH_URL=https://ton618-bot.squareweb.app/health

# Sentry DSN para error tracking en el navegador
# Obtener desde sentry.io → Proyect Settings → Client Keys
VITE_SENTRY_DSN=
